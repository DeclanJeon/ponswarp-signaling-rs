# Local development configuration.
# Copy to .env.local and fill secrets only when testing real integrations.

PONSWARP_ENV=local
HOST=127.0.0.1
PORT=5502
LOG_LEVEL=debug
CORS_ORIGINS=http://localhost:3500,http://127.0.0.1:3500

MAX_ROOM_SIZE=4
ROOM_TIMEOUT=3600000

TURN_SERVER_URL=turn:localhost:3478
TURN_SECRET=replace-with-local-coturn-static-auth-secret
TURN_REALM=localhost
TURN_ENABLE_TLS=false
TURN_ENABLE_UDP=true
TURN_ENABLE_TCP=true
TURN_PORT_UDP=3478
TURN_PORT_TCP=3478
TURN_PORT_TLS=443
TURN_CREDENTIAL_TTL=3600
TURN_FALLBACK_SERVERS=stun:stun.l.google.com:19302

PONSWARP_CLOUD_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_REGION=auto
PONSWARP_CLOUD_PREFIX=ponswarp-local
PONSWARP_CLOUD_RETENTION_SECONDS=86400
PONSWARP_CLOUD_UPLOAD_URL_TTL_SECONDS=3600
PONSWARP_CLOUD_DOWNLOAD_URL_TTL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_INTERVAL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_RUN_ON_STARTUP=true
PONSWARP_CLOUD_MAX_FILES=100
PONSWARP_CLOUD_MAX_FILE_BYTES=10737418240
PONSWARP_CLOUD_MAX_TOTAL_BYTES=10737418240

PONSWARP_BILLING_ENABLED=false
PONSWARP_PUBLIC_APP_URL=http://localhost:3500
PONSWARP_PUBLIC_API_URL=http://localhost:5502
PONSWARP_DEFAULT_PAYMENT_PROVIDER=lemonsqueezy

GOOGLE_CLIENT_ID=replace-with-local-google-web-client-id
GOOGLE_CLIENT_SECRET=replace-with-local-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5502/auth/google/callback
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_COOKIE_NAME=ponswarp_session_local
AUTH_SESSION_TTL_SECONDS=2592000
ADMIN_BOOTSTRAP_EMAILS=

LEMONSQUEEZY_API_BASE=https://api.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_DROP_100GB_3D=
LEMONSQUEEZY_VARIANT_DROP_500GB_7D=
LEMONSQUEEZY_VARIANT_DROP_1TB_7D=
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=

PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_DEFAULT_CURRENCY=USD
PAYPAL_PRO_PLAN_ID=
PAYPAL_WEBHOOK_ID=

DATABASE_URL=postgres://ponswarp:replace-password@127.0.0.1:5432/ponswarp
DATABASE_MAX_CONNECTIONS=5
DATABASE_RUN_MIGRATIONS=true
