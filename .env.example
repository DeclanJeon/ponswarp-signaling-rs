HOST=0.0.0.0
PORT=5502
LOG_LEVEL=info
CORS_ORIGINS=https://warp.ponslink.com

MAX_ROOM_SIZE=4
ROOM_TIMEOUT=3600000

TURN_SERVER_URL=turn:warp.ponslink.com:3478
TURN_SECRET=replace-with-coturn-static-auth-secret
TURN_REALM=warp.ponslink.com
TURN_ENABLE_TLS=false
TURN_ENABLE_UDP=true
TURN_ENABLE_TCP=true
TURN_PORT_UDP=3478
TURN_PORT_TCP=3478
TURN_PORT_TLS=443
TURN_CREDENTIAL_TTL=3600
TURN_FALLBACK_SERVERS=stun:stun.l.google.com:19302

PONSWARP_CLOUD_ENABLED=true
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=ponslink
R2_ENDPOINT=https://replace-with-cloudflare-account-id.r2.cloudflarestorage.com
R2_REGION=auto
PONSWARP_CLOUD_PREFIX=ponswarp-cloud
PONSWARP_CLOUD_RETENTION_SECONDS=86400
PONSWARP_CLOUD_UPLOAD_URL_TTL_SECONDS=3600
PONSWARP_CLOUD_DOWNLOAD_URL_TTL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_INTERVAL_SECONDS=300
PONSWARP_CLOUD_CLEANUP_RUN_ON_STARTUP=true
PONSWARP_CLOUD_MAX_FILES=100
PONSWARP_CLOUD_MAX_FILE_BYTES=10737418240
PONSWARP_CLOUD_MAX_TOTAL_BYTES=10737418240

PONSWARP_BILLING_ENABLED=false
PONSWARP_PUBLIC_APP_URL=https://warp.ponslink.com
PAYPAL_API_BASE=https://api-m.paypal.com
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_WEBHOOK_ID=replace-with-paypal-webhook-id
PAYPAL_PRO_PLAN_ID=replace-with-paypal-subscription-plan-id
DATABASE_URL=postgres://ponswarp:replace-password@127.0.0.1:5432/ponswarp
DATABASE_MAX_CONNECTIONS=5
DATABASE_RUN_MIGRATIONS=true
